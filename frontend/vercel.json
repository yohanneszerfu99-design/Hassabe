{
  "version": 2,
  "name": "hassabe",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/auth.html"
    },
    {
      "src": "/login",
      "dest": "/auth.html"
    },
    {
      "src": "/signup",
      "dest": "/auth.html"
    },
    {
      "src": "/dashboard",
      "dest": "/matches.html"
    },
    { "src": "/matches", 
      "dest": "/matches.html" },
    {
      "src": "/profile",
      "dest": "/onboarding.html"
    },
    { "src": "/payment", 
      "dest": "/payment.html" },
    {
      "src": "/chat",
      "dest": "/chat.html"
    },
    { "src": "/messages", 
      "dest": "/chat.html" },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/firebase-messaging-sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
