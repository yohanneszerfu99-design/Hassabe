# ═══════════════════════════════════════════════════
#  HASSABE — Environment Variables
#  Copy this file to .env and fill in all values.
#  Never commit .env to git.
# ═══════════════════════════════════════════════════

# ── Database (Supabase) ──────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ── JWT Auth ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-character-random-secret-here

# ── Frontend URL (used for Stripe redirect + CORS) ───
FRONTEND_URL=https://hassabe.com

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
# Emails send from: admin@hassabe.com
# Add admin.hassabe.com as a sending domain in Resend dashboard

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_GOLD_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_GOLD_ANNUAL_PRICE_ID=price_your_annual_price_id

# ── Cloudinary (voice notes only — no photos) ─────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Firebase (push notifications) ────────────────────
# Paste the minified single-line JSON from your Firebase service account file
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── App Config ────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Conversation Unlock Price (cents) ────────────────
CONVERSATION_UNLOCK_PRICE=4999
